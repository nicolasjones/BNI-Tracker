{
  "name": "bni-tracker",
  "private": true,
  "version": "0.1.0",
  "description": "BNI Track engineering foundation monorepo.",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "format:check": "prettier --check .",
    "typecheck": "npm --workspace apps/web run typecheck",
    "test": "npm run test:ts && npm run test:py",
    "test:ts": "npm --workspace apps/web run test",
    "test:py": "python3 -m pytest services/ai/tests",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build:web",
    "smoke:ai": "node scripts/smoke-web-ai.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "prettier": "^3.3.2"
  }
}
