#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
CODEX_HOME_DIR="${REPO_ROOT}/.atl/codex-home"
CERT_FILE="${SSL_CERT_FILE:-/Library/Frameworks/Python.framework/Versions/3.14/lib/python3.14/site-packages/certifi/cacert.pem}"

if [[ ! -f "${CERT_FILE}" ]]; then
  echo "CA bundle not found at: ${CERT_FILE}" >&2
  echo "Install certifi for Python 3.14 or export SSL_CERT_FILE manually." >&2
  exit 1
fi

mkdir -p "${CODEX_HOME_DIR}"

export CODEX_HOME="${CODEX_HOME_DIR}"
export SSL_CERT_FILE="${CERT_FILE}"
export REQUESTS_CA_BUNDLE="${CERT_FILE}"
export CURL_CA_BUNDLE="${CERT_FILE}"

exec codex \
  --enable multi_agent \
  --cd "${REPO_ROOT}" \
  --sandbox workspace-write \
  --ask-for-approval on-request \
  "$@"
